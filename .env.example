# -----------------------------------------------------------
# PostAud.io — environment variables
# Copy to .env.local for local dev. Managed in Vercel per-env.
# Keep this file in sync with src/lib/env.ts.
# -----------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=hello@postaud.io

# Vercel Cron auth — shared secret sent by the interview-processing tick route
CRON_SECRET=

# Platform admin — comma-separated list of emails granted super-admin access
PLATFORM_ADMIN_EMAILS=
